# Copy to .env and edit. Env vars beat yaml. Nested keys joined by '__'.
CODE_ATLAS_APP__LOG_LEVEL=INFO
CODE_ATLAS_APP__LOG_JSON=true
CODE_ATLAS_INGESTION__MAX_CHUNK_LINES=200
CODE_ATLAS_STORAGE__ROOT_DIR=./data
CODE_ATLAS_EMBEDDINGS__PROVIDER=ollama
CODE_ATLAS_EMBEDDINGS__MODEL=nomic-embed-text
CODE_ATLAS_EMBEDDINGS__DIMENSION=768
CODE_ATLAS_CHAT__PROVIDER=ollama
CODE_ATLAS_CHAT__MODEL=llama3.1
CODE_ATLAS_CHAT__TEMPERATURE=0.2
CODE_ATLAS_OLLAMA__BASE_URL=http://localhost:11434
CODE_ATLAS_OLLAMA__TIMEOUT_S=60.0
CODE_ATLAS_EVAL__COST_RATES_PATH=config/costs.yaml
